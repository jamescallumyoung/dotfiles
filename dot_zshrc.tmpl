export PATH="/Users/jamesyoung/.minishift/cache/oc/v3.11.141/darwin:$PATH"

# interactive shell options
unsetopt beep

# History
export HISTCONTROL=ignorespace
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000
setopt appendhistory autocd

# Aliases for builtins
alias ll="ls -lhF"
alias lla="ll -a"
alias l="ls -1"
alias la="l -a"
alias rm="rm -i"
alias cl="clear"

# Restart gpg-agent
alias gpg-agent-restart="gpgconf --kill gpg-agent"

{{ if eq .chezmoi.os "linux" }}
  # Alias open on non-darwin systems
  alias open="xdg-open"
{{ end }}

##################################################################
# APP SPECIFIC ###################################################

# public-transport-lib
alias sbb="public-transport-lib"

# calendar
export CALENDAR_DIR="${HOME}/.calendar"

# todo.sh
alias todo="todo.sh"

# Docker
alias doco="docker-compose"

# Fuck
eval $(thefuck --alias)
alias f="fuck"

# twtxt
alias twtxt="twtxt -c .config/twtxt/conf"

# Git
alias gf="git fetch --prune"
alias gfl="git fetch --prune && git pull"
alias grmm="git branch --merged | egrep -v '(master|dev|develop)' | xargs git branch -d"
alias gbc='gco $(gba | pick)'

# hub (GitHub cli)
eval "$(hub alias -s)"

# 1password (op)
alias opsignin='eval $(op signin my)'

# jenv
eval "$(jenv init -)"

##################################################################
# LANG SPECIFIC ##################################################

# Python
alias py="python3"

# Java
{{ if eq .chezmoi.os "darwin" }} # MacOS only
  # add the system java version to PATH
  export JAVA_HOME=$(/usr/libexec/java_home)
{{ end }}

