# Antigen (oh-my-zsh)

{{ if eq .chezmoi.os "linux" }}
  source /usr/share/zsh-antigen/antigen.zsh # source the antigen lib
  source $HOME/.antigenrc # apply our antigen configs
{{ end }}
{{ if eq .chezmoi.os "darwin" }}
  source /usr/local/share/antigen/antigen.zsh # source the antigen lib
  source $HOME/.antigenrc # apply our antigen configs
{{ end }}

# (Temp) minishift stuff

